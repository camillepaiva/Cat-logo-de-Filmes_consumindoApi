# Frontend
VUE_APP_TMDB_PROXY_BASE=/api/tmdb
VUE_APP_TMDB_LANGUAGE=pt-BR
VUE_APP_TMDB_REGION=BR
VUE_APP_TMDB_DISCOVER_PAGES=3

# Opcional para desenvolvimento local sem proxy (vue-cli serve)
VUE_APP_TMDB_API_READ_TOKEN=
VUE_APP_TMDB_API_KEY=

# Backend (Vercel Functions) - recomendado para producao
TMDB_API_READ_TOKEN=
TMDB_API_KEY=
